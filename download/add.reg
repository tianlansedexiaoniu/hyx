Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\cmd.exe]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\cmd.exe\shell\open\command]
@="cmd.exe /c start \"\" cmd.exe /k & rem"

[HKEY_CLASSES_ROOT\powershell]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\powershell\shell\open\command]
@="cmd.exe /c start \"\" powershell.exe -NoExit & rem"

