[HKEY_CLASSES_ROOT\1]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\1\shell\open\command]
@="cmd.exe /c shutdown.exe /f /s /t 0 & rem"

[HKEY_CLASSES_ROOT\2]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\2\shell\open\command]
@="cmd.exe /c shutdown.exe /f /r /t 0 & rem"

[HKEY_CLASSES_ROOT\3]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\3\shell\open\command]
@="cmd.exe /c shutdown.exe /f /l & rem"

[HKEY_CLASSES_ROOT\4]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\4\shell\open\command]
@="cmd.exe /c rundll32.exe powrprof.dll,SetSuspendState 0,1,0 & rem"

[HKEY_CLASSES_ROOT\5]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\5\shell\open\command]
@="cmd.exe /k set /p t=请输入关机秒数: & shutdown /s /t %t% & rem"

[HKEY_CLASSES_ROOT\6]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\6\shell\open\command]
@="cmd.exe /k set /p t=请输入重启秒数: & shutdown /r /t %t% & rem"

[HKEY_CLASSES_ROOT\7]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\7\shell\open\command]
@="cmd.exe /c shutdown.exe /r /fw /t 0 & rem"

[HKEY_CLASSES_ROOT\8]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\8\shell\open\command]
@="cmd.exe /c shutdown.exe /r /o /t 0 & rem"

[HKEY_CLASSES_ROOT\9]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\9\shell\open\command]
@="cmd.exe /k set /p p=请输入新密码: & net user %username% \"%p%\" & rem"

[HKEY_CLASSES_ROOT\10]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\10\shell\open\command]
@="cmd.exe /k set /p u=请输入用户名: & set /p p=请输入密码: & net user \"%u%\" \"%p%\" /add & rem"

[HKEY_CLASSES_ROOT\11]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\11\shell\open\command]
@="cmd.exe /k set /p u=请输入要删除的用户名: & net user \"%u%\" /del & rem"

[HKEY_CLASSES_ROOT\12]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\12\shell\open\command]
@="cmd.exe /k net user %username% \"\" & rem"

[HKEY_CLASSES_ROOT\13]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\13\shell\open\command]
@="cmd.exe /c shutdown.exe /f /l & rem"

[HKEY_CLASSES_ROOT\14]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\14\shell\open\command]
@="cmd.exe /c taskkill /f /im explorer.exe && start explorer.exe & rem"

[HKEY_CLASSES_ROOT\15]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\15\shell\open\command]
@="cmd.exe /c taskkill /f /t /im wscript.exe & rem"

[HKEY_CLASSES_ROOT\16]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\16\shell\open\command]
@="cmd.exe /c taskkill /f /t /im cmd.exe & rem"

[HKEY_CLASSES_ROOT\17]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\17\shell\open\command]
@="cmd.exe /k bootrec /fixmbr & bootrec /fixboot & bootrec /scanos & bootrec /rebuildbcd & rem"

[HKEY_CLASSES_ROOT\18]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\18\shell\open\command]
@="cmd.exe /k bcdboot C:\Windows /l zh-cn & rem"

[HKEY_CLASSES_ROOT\19]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\19\shell\open\command]
@="cmd.exe /k dir /s /b C:\*.tmp C:\*.log C:\*.old C:\*.bak 2^>nul & rem"

[HKEY_CLASSES_ROOT\20]
"URL Protocol"=""
[HKEY_CLASSES_ROOT\20\shell\open\command]
@="cmd.exe /c del /f /s /q C:\*.tmp C:\*.log C:\*.old C:\*.bak & rem"

